text.usetex: True
text.latex.preamble: \usepackage{amsmath}\usepackage{amssymb}


savefig.bbox: tight
savefig.format: pdf

figure.figsize : 3.3, 2.5
figure.dpi : 600

font.size : 8
font.family : serif

font.serif : Times

legend.fontsize: 8
axes.labelsize: 8
legend.markerscale:   1.0      # the relative size of legend markers vs. original